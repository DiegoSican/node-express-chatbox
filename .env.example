# =============================================================
# .env.example — Variables de entorno del proyecto
# Proyecto: node-express-chatbox
#
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo como .env
#    Comando: cp .env.example .env
# 2. Cambia los valores según tu entorno
# =============================================================

# Puerto donde va a correr la aplicación
# Valor por defecto: 3001
# Para acceder abre: http://localhost:3001
PORT=3001

# Entorno de ejecución
# Valores válidos: development, production
NODE_ENV=development
